# Local workflow config — edit paths for your machine
# Usage (from repo root): source scripts/private_scripts/config.env && scripts/public/shared_scripts/run_retrieval_rerank_pipeline.sh
#
# Same parameter names as scripts/public/workflow_config_full.env.
# TOP_K = retrieval depth for all stages (k_eval / topk / cap / candidate_limit).

REPO_ROOT=/Users/yun/develop/RAG-orange

HAVE_GROUND_TRUTH=0
RUN_BASELINE=1
RUN_SNIPPET_RRF=0

# ---------- Shared ----------
WORKFLOW_OUTPUT_DIR=$REPO_ROOT/output/
TRAIN_JSON=$REPO_ROOT/data/train_test_dataset_bioasq_style/orange_qa_MCQ_test_bioasq.json
TEST_BATCH_JSONS="$REPO_ROOT/data/train_test_dataset_bioasq_style/orange_qa_MCQ-con_test_bioasq.json"

# ---------- Query fields (use question-only text for retrieval/rerank) ----------
BM25_QUERY_FIELD=body_query
DENSE_QUERY_FIELD=body_query
RERANK_QUERY_FIELD=body_query

TOP_K=80

# ---------- Index paths (local) ----------
BM25_INDEX_PATH=$REPO_ROOT/index/bm25
DENSE_INDEX_DIR=$REPO_ROOT/index/bg3_m3

# ---------- BM25 ----------
# BM25_JAVA_MEM=8g
BM25_THREADS=4
BM25_DISABLE_RM3=1 
BM25_INCLUDE_BASELINE=1
BM25_SAVE_RUNS=1
BM25_SAVE_PER_QUERY=1
# BM25_SAVE_ZERO_RECALL=1

# ---------- Dense ----------
DENSE_DEVICE=mps
DENSE_BATCH_SIZE=32

# ---------- Hybrid ----------
HYBRID_MODE=default
HYBRID_JOBS=4
HYBRID_K_RRF=60
HYBRID_W_BM25=1.0
# HYBRID_W_DENSE=1.0

# ---------- Reranker ----------
DOCS_JSONL=$REPO_ROOT/data/orange_docs_chunks.jsonl
RERANK_CANDIDATE_LIMIT=20
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
RERANK_MODEL_DEVICE=mps
RERANK_MODEL_BATCH=8

# ---------- RRF fusion (Hybrid + Rerank, top-10) ----------
#RUN_RRF_FUSION=0

# ---------- Evidence (post-rerank JSON + contexts JSONL) ----------
EVIDENCE_TOP_K=5

# ---------- Generation ----------
# These can be tuned or left unset to use defaults in generate_answers.py.
# GENERATION_CONCURRENCY=1
GENERATION_MAX_CONTEXTS=3
GENERATION_MAX_CHARS_PER_CONTEXT=2000
GENERATION_SYSTEM_PATH=/Users/yun/develop/RAG-orange/scripts/prompts/system.txt
GENERATION_SCHEMAS_DIR=/Users/yun/develop/RAG-orange/scripts/prompts/schemas