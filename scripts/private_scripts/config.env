# Local workflow config — edit paths for your machine
# Usage (from repo root): source scripts/private_scripts/config.env && scripts/public/shared_scripts/run_retrieval_rerank_pipeline.sh
#
# Same parameter names as scripts/public/workflow_config_full.env.
# TOP_K = retrieval depth for all stages (k_eval / topk / cap / candidate_limit).

REPO_ROOT=/Users/yun/develop/BioASQ

# ---------- Shared ----------
WORKFLOW_OUTPUT_DIR=$REPO_ROOT/output/workflow_local_10pct
TRAIN_JSON=$REPO_ROOT/example/training14b_10pct_sample.json
TEST_BATCH_JSONS="$REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B1_golden.json $REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B2_golden.json $REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B3_golden.json $REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B4_golden.json"

TOP_K=5000
RECALL_KS=50,100,200,300,400,500,1000,2000,5000

# ---------- Index paths (local) ----------
BM25_INDEX_PATH=$REPO_ROOT/output/pubmed_bm25_2026_subset_index
DENSE_INDEX_DIR=/Users/yun/develop/pubmed_medembed_2026_subset_index

# ---------- BM25 ----------
# BM25_JAVA_MEM=8g
BM25_THREADS=4
# BM25_RM3_FEEDBACK_POOL=50
# BM25_RM3_FB_DOCS=20
# BM25_RM3_FB_TERMS=30
# BM25_RM3_LAMBDA=0.6
# BM25_INCLUDE_BASELINE=1
BM25_SAVE_RUNS=1
BM25_SAVE_PER_QUERY=1
# BM25_SAVE_ZERO_RECALL=1

# ---------- Dense ----------
DENSE_EF_CAP=2000
# DENSE_DEVICE=cpu
# DENSE_BATCH_SIZE=256

# ---------- Hybrid ----------
HYBRID_MODE=default
HYBRID_JOBS=4
# HYBRID_K_RRF=150
# HYBRID_W_BM25=1.0
# HYBRID_W_DENSE=1.0

# ---------- Reranker ----------
DOCS_JSONL=$REPO_ROOT/output/subset_pubmed.jsonl
# RERANK_CANDIDATE_LIMIT=2000
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2
# RERANK_MODEL_DEVICE=cpu
# RERANK_MODEL_BATCH=16
# RERANK_USE_MULTI_GPU=1   # set to 1 to use multiple GPUs
# RERANK_NUM_GPUS=0        # 0 = use all available GPUs
