REPO_ROOT=/work

# ---------- Ground truth (eval metrics) ----------
# HAVE_GROUND_TRUTH=1   # set to 0 to skip all eval metrics (BM25, Dense, Hybrid, Rerank)

RUN_BASELINE=1          # build baseline evidence/generation (default: 1)
RUN_SNIPPET_RRF=1       # run snippet-rrf route (steps 6–7, evidence_snippet/, generation_snippet/)

# ---------- Shared ----------
WORKFLOW_OUTPUT_DIR=$REPO_ROOT/output/workflow_baseline_full_run_both_routes
TRAIN_JSON=$REPO_ROOT/example/training14b_10pct_sample.json
TEST_BATCH_JSONS="$REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B1_golden.json $REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B2_golden.json $REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B3_golden.json $REPO_ROOT/bioasq_data/Task13BGoldenEnriched/13B4_golden.json"

TOP_K=5000
RECALL_KS=50,100,200,300,400,500,1000,2000,5000

# ---------- Index paths ----------
BM25_INDEX_PATH=/pubmed/pubmed_bm25_2026_index
# Use sharded dense index built at /pubmed/pubmed_medembed_shard00-09
DENSE_INDEX_GLOB=/pubmed/pubmed_medembed_shard0*

# ---------- BM25 ----------
BM25_THREADS=8
BM25_SAVE_RUNS=1
BM25_SAVE_PER_QUERY=1

# ---------- Dense ----------
# DENSE_EF_CAP=5000
# DENSE_DEVICE=cuda
# DENSE_BATCH_SIZE=256

# ---------- Hybrid ----------
HYBRID_MODE=default
HYBRID_JOBS=8

# ---------- Reranker ----------
# For now, reuse the subset corpus JSONL for contexts; adjust if you have a full concatenated corpus.
DOCS_JSONL=/pubmed/jsonl_2026/*.jsonl
RERANK_CANDIDATE_LIMIT=1000
RERANK_MODEL=BAAI/bge-reranker-v2-m3 
RERANK_MODEL_DEVICE=cuda
RERANK_MODEL_BATCH=64
RERANK_MODEL_MAX_LENGTH=512
# RERANK_USE_MULTI_GPU=1
# RERANK_NUM_GPUS=3

# ---------- Generation ----------
# These can be tuned or left unset to use defaults in generate_answers.py.
# GENERATION_CONCURRENCY=1
# GENERATION_MAX_CONTEXTS=8
# GENERATION_MAX_CHARS_PER_CONTEXT=1300
GENERATION_SLEEP=0.5
GENERATION_MODEL=qwen3:32b-q8_0
